{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build-${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_C_COMPILER": "port-cc"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux 32-bit Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-g -O0"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux 32-bit Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_FLAGS": "-O2"
            }
        },
        {
            "name": "linux-debug-make",
            "displayName": "Linux 32-bit Debug (Make fallback)",
            "inherits": "linux-debug",
            "generator": "Unix Makefiles"
        },
        {
            "name": "windows",
            "displayName": "Windows 32-bit (MinGW)",
            "inherits": "base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        },
        {
            "name": "macos",
            "displayName": "macOS 32-bit",
            "inherits": "base",
            "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug" }
        }
    ],
    "buildPresets": [
        { "name": "linux-debug",   "configurePreset": "linux-debug" },
        { "name": "linux-release", "configurePreset": "linux-release" },
        { "name": "linux-debug-make", "configurePreset": "linux-debug-make" },
        { "name": "windows",       "configurePreset": "windows" },
        { "name": "macos",         "configurePreset": "macos" }
    ]
}
