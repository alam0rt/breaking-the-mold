output
tools/gcc-builds
tools/gcc-2.7.2-sn32/wineprefix
tools/gcc-2.7.2-sn32/work
bin/*
nonmatchings/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
build/
*.o
*.elf
*.bin
*.map

# PC port (docs/plans/pc-port.md): CMake build trees. The generated weak-stub /
# global TUs (port/decomp/_auto*.c) ARE committed so the tree links without
# running the generator; the CMake build directories are not.
port/build-*/
port/build/

# misc

*.jsonl

# -----------------------------------------------------------------------------
# Generated files (from splat extraction)
# -----------------------------------------------------------------------------
asm/
/assets/

# Analysis build: generated per-header layout-assert TUs (regenerated by
# `make analyze`; the generator + baseline are committed, the output is not).
tools/analysis/asserts/

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
pip-log.txt
pip-delete-this-directory.txt
.eggs/
*.egg-info/
*.egg

# -----------------------------------------------------------------------------
